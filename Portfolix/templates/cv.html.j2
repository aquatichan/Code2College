<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ profile.name }} — Technical CV</title>
  <style>
    @page { size: A4; margin: 18mm 16mm; }
    * { box-sizing: border-box; }
    body {
      font: 10.5pt/1.45 "Helvetica Neue", Helvetica, Arial, sans-serif;
      color: #1a1a1a; margin: 0;
    }
    a { color: #0b5cad; text-decoration: none; }

    header { border-bottom: 2px solid #1a1a1a; padding-bottom: 10px; margin-bottom: 16px; }
    h1 { font-size: 22pt; margin: 0 0 2px; letter-spacing: -.3px; }
    .contact { font-size: 9pt; color: #444; }
    .contact span { margin-right: 12px; white-space: nowrap; }
    .summary { margin-top: 8px; font-size: 10pt; color: #333; }

    h2 {
      font-size: 11pt; text-transform: uppercase; letter-spacing: .6px;
      border-bottom: 1px solid #ccc; padding-bottom: 3px; margin: 18px 0 10px;
      color: #0b5cad;
    }

    .stats-row { display: flex; gap: 0; margin-bottom: 4px; }
    .stats-row .cell { flex: 1; text-align: center; }
    .stats-row .num { font-size: 15pt; font-weight: 700; }
    .stats-row .lbl { font-size: 7.5pt; text-transform: uppercase; color: #666; letter-spacing: .5px; }

    .langbar { display: flex; height: 9px; border-radius: 4px; overflow: hidden; border: 1px solid #ddd; margin-bottom: 6px; }
    .langbar > span { display: block; height: 100%; }
    .langlegend { font-size: 8.5pt; color: #444; }
    .langlegend span { margin-right: 14px; white-space: nowrap; }
    .langlegend .dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 4px; }

    .project { margin-bottom: 11px; page-break-inside: avoid; }
    .project .top { display: flex; justify-content: space-between; align-items: baseline; }
    .project .name { font-weight: 700; font-size: 10.5pt; }
    .project .stars { font-size: 8.5pt; color: #666; white-space: nowrap; }
    .project .desc { font-size: 9.5pt; color: #333; margin: 1px 0; }
    .project .tech { font-size: 8pt; color: #777; }

    footer { margin-top: 20px; font-size: 8pt; color: #999; text-align: center; border-top: 1px solid #eee; padding-top: 6px; }
  </style>
</head>
<body>
  <header>
    <h1>{{ profile.name }}</h1>
    <div class="contact">
      {% if profile.location %}<span>📍 {{ profile.location }}</span>{% endif %}
      {% if profile.company %}<span>🏢 {{ profile.company }}</span>{% endif %}
      <span>🔗 {{ profile.html_url }}</span>
      {% if profile.blog %}<span>🌐 {{ profile.blog }}</span>{% endif %}
    </div>
    {% if profile.bio %}<div class="summary">{{ profile.bio }}</div>{% endif %}
  </header>

  <h2>At a Glance</h2>
  <div class="stats-row">
    <div class="cell"><div class="num">{{ profile.public_repos }}</div><div class="lbl">Public Repos</div></div>
    <div class="cell"><div class="num">{{ d.total_stars }}</div><div class="lbl">Total Stars</div></div>
    <div class="cell"><div class="num">{{ d.total_forks }}</div><div class="lbl">Total Forks</div></div>
    <div class="cell"><div class="num">{{ profile.followers }}</div><div class="lbl">Followers</div></div>
    {% if d.contributions is not none %}
    <div class="cell"><div class="num">{{ d.contributions }}</div><div class="lbl">Contribs/yr</div></div>
    {% endif %}
  </div>

  {% if d.languages %}
  <h2>Technical Skills</h2>
  <div class="langbar">
    {% for lang, pct in d.languages[:8] %}
    <span style="width: {{ pct }}%; background: {{ lang|lang_color }};"></span>
    {% endfor %}
  </div>
  <div class="langlegend">
    {% for lang, pct in d.languages[:8] %}
    <span><span class="dot" style="background: {{ lang|lang_color }}"></span>{{ lang }} ({{ pct }}%)</span>
    {% endfor %}
  </div>
  {% endif %}

  {% if d.pinned %}
  <h2>Featured Projects</h2>
  {% for r in d.pinned %}
  <div class="project">
    <div class="top">
      <span class="name">{{ r.name }}</span>
      <span class="stars">★ {{ r.stars }} · ⑂ {{ r.forks }}</span>
    </div>
    <div class="desc">{{ r.ai_summary or r.description or "—" }}</div>
    <div class="tech">
      {% if r.language %}{{ r.language }}{% endif %}
      {% if r.topics %}· {{ r.topics[:5]|join(", ") }}{% endif %}
      · {{ r.url }}
    </div>
  </div>
  {% endfor %}
  {% endif %}

  <footer>Generated by Portfolix on {{ generated_on }} · github.com/{{ profile.login }}</footer>
</body>
</html>
