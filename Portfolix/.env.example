# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# GitHub username to build the portfolio for (required unless passed via --username).
GITHUB_USERNAME=

# GitHub token — OPTIONAL. Portfolix uses only the public GitHub API and needs
# NO token. A token here does one thing: raises the rate limit from 60 to 5000
# requests/hr. Leave it blank unless you hit the limit.
# (Create at https://github.com/settings/tokens — public read access is enough.)
GITHUB_TOKEN=

# Gemini API key — OPTIONAL. If set, Portfolix uses Gemini to: polish your bio,
# write one-line project summaries, an about/ambitions narrative, a cover letter,
# a brag sheet, AND an AI "Beautify" style pack for the site. Everything still
# works without it (built-in text is used instead).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
